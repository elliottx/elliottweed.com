---
import Layout from '../layouts/Layout.astro';
import timeline from '../data/timeline.json';

interface TimelineEvent {
  year: number;
  month?: string;
  title: string;
  description: string;
  icon: string;
  category: string;
  image?: string;
}
---

<Layout title="Elliott Weed — Senior AI & Data Success Architect">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- STICKY NAV                                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <nav class="sticky-nav" id="sticky-nav" aria-label="Main navigation">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
      <a href="#" class="text-white font-bold text-lg tracking-tight">
        E<span class="text-gradient">W</span>
      </a>
      <div class="flex items-center gap-6 md:gap-8">
        <a href="#timeline" class="nav-link text-sm text-slate-400 hover:text-white transition-colors">Journey</a>
        <a href="#expertise" class="nav-link text-sm text-slate-400 hover:text-white transition-colors">Expertise</a>
        <a href="#testimonials" class="nav-link text-sm text-slate-400 hover:text-white transition-colors hidden md:block">Testimonials</a>
        <a href="#contact" class="nav-link text-sm text-slate-400 hover:text-white transition-colors hidden sm:block">Contact</a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO                                                        -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="hero-section flex items-center justify-center" id="hero">
    <!-- Ambient orbs -->
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-1" id="orb1" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-2" id="orb2" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-3" id="orb3" aria-hidden="true"></div>

    <!-- Canvas for particles -->
    <canvas id="hero-canvas" aria-hidden="true"></canvas>

    <!-- Grid pattern -->
    <div class="grid-pattern" aria-hidden="true"></div>

    <div class="max-w-5xl mx-auto px-6 text-center relative z-10 py-32">

      <!-- Headshot -->
      <div class="mb-10" id="hero-photo">
        <div class="headshot-ring inline-block">
          <img
            src="/photos/Headshot2024.jpg"
            alt="Elliott Weed"
            width="160"
            height="160"
            class="headshot-img w-36 h-36 md:w-44 md:h-44 object-cover"
            loading="eager"
          />
        </div>
      </div>

      <!-- Name -->
      <h1 class="text-5xl sm:text-6xl md:text-8xl font-extrabold tracking-tight mb-6 leading-[1.05]" id="hero-name">
        <span class="text-white">Elliott </span><span class="text-gradient">Weed</span>
      </h1>

      <!-- Title -->
      <p class="text-lg sm:text-xl md:text-2xl font-medium text-slate-400 mb-5 tracking-wide" id="hero-title">
        Senior AI & Data Success Architect
        <span class="mx-2 text-slate-600">|</span>
        <span class="text-blue-400">Salesforce</span>
      </p>

      <!-- Subtitle -->
      <p class="text-base md:text-lg text-slate-500 max-w-2xl mx-auto mb-14 leading-relaxed" id="hero-sub">
        17+ years turning complex technical problems into elegant solutions.
        From small-town Oregon to architecting AI for the world's largest companies.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 md:gap-6 max-w-2xl mx-auto" id="hero-stats">
        <div class="stat-card text-center">
          <div class="text-3xl md:text-4xl font-bold text-white stat-number" data-target="17">0</div>
          <div class="text-xs md:text-sm text-slate-500 mt-1.5 uppercase tracking-wider">Years in Tech</div>
        </div>
        <div class="stat-card text-center">
          <div class="text-3xl md:text-4xl font-bold text-white stat-number" data-target="9">0</div>
          <div class="text-xs md:text-sm text-slate-500 mt-1.5 uppercase tracking-wider">Certifications</div>
        </div>
        <div class="stat-card text-center">
          <div class="text-3xl md:text-4xl font-bold text-white stat-number" data-target="5">0</div>
          <div class="text-xs md:text-sm text-slate-500 mt-1.5 uppercase tracking-wider">Companies Shaped</div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-20" id="scroll-hint">
        <div class="flex flex-col items-center text-slate-600">
          <span class="text-xs uppercase tracking-[0.2em] mb-3">Scroll</span>
          <div class="w-5 h-8 rounded-full border border-slate-600 flex justify-center pt-1.5">
            <div class="w-1 h-2 rounded-full bg-slate-500 animate-bounce"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- TIMELINE                                                    -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-32 md:py-40 relative" id="timeline">
    <div class="grid-pattern" aria-hidden="true"></div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">

      <div class="text-center mb-24 md:mb-32">
        <div class="section-divider" id="timeline-divider"></div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4" id="timeline-heading">
          The <span class="text-gradient">Journey</span>
        </h2>
        <p class="text-slate-500 text-lg" id="timeline-sub">Every milestone tells a story</p>
      </div>

      <div class="relative" id="timeline-container">
        <!-- Vertical timeline line -->
        <div class="timeline-line hidden md:block" aria-hidden="true">
          <div class="timeline-line-bg"></div>
          <div class="timeline-line-fill" id="timeline-fill"></div>
        </div>

        {timeline.map((event: TimelineEvent, index: number) => (
          <div
            class={`timeline-event mb-16 md:mb-24 flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-10 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}
            data-category={event.category}
            data-index={index}
          >
            {/* Content card */}
            <div class={`flex-1 w-full ${index % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
              <div class="glass-card overflow-hidden">
                <div class="glass-card-glow" style={`background: radial-gradient(circle at ${index % 2 === 0 ? '80%' : '20%'} 50%, ${event.category === 'life' ? 'rgba(16, 185, 129, 0.06)' : event.category === 'career' ? 'rgba(59, 130, 246, 0.06)' : 'rgba(139, 92, 246, 0.06)'}, transparent 60%);`} aria-hidden="true"></div>
                {event.image && (
                  <div class="timeline-image-wrap">
                    <img 
                      src={event.image} 
                      alt={event.title}
                      class="timeline-image w-full h-40 md:h-48 object-cover"
                      loading="lazy"
                    />
                    <div class="timeline-image-overlay" aria-hidden="true"></div>
                  </div>
                )}
                <div class="p-6 md:p-8">
                  <div class={`flex items-center gap-3 mb-3 relative ${index % 2 === 0 ? 'md:justify-end' : ''}`}>
                    <span class={`text-[11px] font-semibold uppercase tracking-wider px-3 py-1 rounded-full ${
                      event.category === 'life' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/15' :
                      event.category === 'career' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/15' :
                      'bg-purple-500/10 text-purple-400 border border-purple-500/15'
                    }`}>
                      {event.category}
                    </span>
                  </div>
                  <h3 class="text-lg md:text-xl font-bold text-white mb-2 relative">{event.title}</h3>
                  <p class="text-slate-400 leading-relaxed text-sm md:text-base relative">{event.description}</p>
                </div>
              </div>
            </div>

            {/* Center dot + year */}
            <div class="flex flex-row md:flex-col items-center gap-3 md:gap-2 order-first md:order-none shrink-0">
              <div class="timeline-dot">
                <div class={`timeline-dot-inner w-12 h-12 md:w-14 md:h-14 rounded-full flex items-center justify-center text-xl md:text-2xl border-2 ${
                  event.category === 'life' ? 'bg-emerald-950/50 border-emerald-500/30' :
                  event.category === 'career' ? 'bg-blue-950/50 border-blue-500/30' :
                  'bg-purple-950/50 border-purple-500/30'
                }`}>
                  {event.icon}
                </div>
              </div>
              <span class="year-marker text-base md:text-lg font-bold font-mono text-slate-500">
                {event.year}
              </span>
            </div>

            {/* Spacer for alternating layout */}
            <div class="flex-1 hidden md:block"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- EXPERTISE                                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-32 md:py-40 relative overflow-hidden" id="expertise">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-950/5 to-transparent"></div>
    <div class="grid-pattern" aria-hidden="true"></div>

    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="text-center mb-20">
        <div class="section-divider" id="expertise-divider"></div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4" id="expertise-heading">
          What I <span class="text-gradient">Build</span>
        </h2>
        <p class="text-slate-500 text-lg" id="expertise-sub">
          The intersection of architecture, AI, and customer success
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8" id="expertise-grid">
        <div class="glass-card expertise-card overflow-hidden">
          <div class="glass-card-glow" style="background: radial-gradient(circle at 30% 30%, rgba(59, 130, 246, 0.08), transparent 60%);" aria-hidden="true"></div>
          <div class="expertise-image-wrap">
            <img src="/photos/agentforce-demo.png" alt="Agentforce AI Interface" class="w-full h-36 object-cover" loading="lazy" />
            <div class="expertise-image-overlay" aria-hidden="true"></div>
          </div>
          <div class="p-8">
            <div class="icon-container bg-blue-500/10 border border-blue-500/15 mb-6 relative">
              <span>🤖</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 relative">Agentforce & AI</h3>
            <p class="text-slate-400 text-sm leading-relaxed relative">Architecting autonomous AI agents for enterprise. From strategy through deployment — making Agentforce real for the largest companies on the platform.</p>
          </div>
        </div>

        <div class="glass-card expertise-card overflow-hidden">
          <div class="glass-card-glow" style="background: radial-gradient(circle at 50% 30%, rgba(139, 92, 246, 0.08), transparent 60%);" aria-hidden="true"></div>
          <div class="expertise-image-wrap">
            <img src="/photos/data-cloud-arch.png" alt="Data Cloud Architecture" class="w-full h-36 object-cover" loading="lazy" />
            <div class="expertise-image-overlay" aria-hidden="true"></div>
          </div>
          <div class="p-8">
            <div class="icon-container bg-purple-500/10 border border-purple-500/15 mb-6 relative">
              <span>☁️</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 relative">Data Cloud</h3>
            <p class="text-slate-400 text-sm leading-relaxed relative">Unifying customer data at scale. Design, implementation, and activation of Salesforce Data Cloud for enterprises that need their data to actually work.</p>
          </div>
        </div>

        <div class="glass-card expertise-card overflow-hidden">
          <div class="glass-card-glow" style="background: radial-gradient(circle at 70% 30%, rgba(236, 72, 153, 0.08), transparent 60%);" aria-hidden="true"></div>
          <div class="expertise-image-wrap">
            <img src="/photos/marketing-cloud.png" alt="Marketing Cloud Dashboard" class="w-full h-36 object-cover" loading="lazy" />
            <div class="expertise-image-overlay" aria-hidden="true"></div>
          </div>
          <div class="p-8">
            <div class="icon-container bg-pink-500/10 border border-pink-500/15 mb-6 relative">
              <span>🎯</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 relative">Marketing Cloud</h3>
            <p class="text-slate-400 text-sm leading-relaxed relative">7+ years deep in Marketing Cloud. Engagement, Personalization, and the full stack. From hands-on development to enterprise architecture.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CERTIFICATIONS                                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-32 md:py-40 relative" id="certs">
    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16">
        <div class="section-divider" id="certs-divider"></div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4" id="certs-heading">
          <span class="text-gradient">Certified</span>
        </h2>
        <p class="text-slate-500 text-lg mb-10" id="certs-sub">9 Salesforce certifications and counting</p>
        <div class="certs-badge-image mx-auto mb-12">
          <img 
            src="/photos/salesforce-certs.png" 
            alt="Salesforce Certifications" 
            class="max-w-xs md:max-w-sm mx-auto rounded-2xl border border-white/5 shadow-2xl"
            loading="lazy"
          />
        </div>
      </div>

      <div class="flex flex-wrap justify-center gap-3 md:gap-4" id="certs-grid">
        {[
          "Agentforce Specialist",
          "Data Cloud Consultant",
          "Marketing Cloud Developer",
          "Marketing Cloud Consultant",
          "MC Personalization Consultant",
          "Marketing Cloud Administrator",
          "Email Specialist",
          "Agentforce Associate",
          "Administrator"
        ].map((cert) => (
          <div class="cert-badge px-5 py-3 text-sm font-medium text-slate-300">
            <span class="relative z-10 flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-blue-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {cert}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- TESTIMONIALS                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-32 md:py-40 relative overflow-hidden" id="testimonials">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-950/5 to-transparent"></div>
    <div class="grid-pattern" aria-hidden="true"></div>

    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="text-center mb-20">
        <div class="section-divider" id="testimonials-divider"></div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4" id="testimonials-heading">
          What People <span class="text-gradient">Say</span>
        </h2>
        <p class="text-slate-500 text-lg" id="testimonials-sub">
          From colleagues and clients I've worked with
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8" id="testimonials-grid">
        <div class="glass-card testimonial-card p-8">
          <div class="glass-card-glow" style="background: radial-gradient(circle at 30% 30%, rgba(59, 130, 246, 0.06), transparent 60%);" aria-hidden="true"></div>
          <div class="flex items-center gap-1 mb-4 relative">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-slate-300 text-sm leading-relaxed mb-6 relative italic">"Elliott's ability to translate complex technical requirements into actionable solutions is unmatched. His work on our Data Cloud implementation transformed how we understand our customers."</p>
          <div class="flex items-center gap-3 relative">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white font-bold text-sm">JM</div>
            <div>
              <div class="text-white font-medium text-sm">Jennifer Martinez</div>
              <div class="text-slate-500 text-xs">VP of Marketing, Fortune 500 Retailer</div>
            </div>
          </div>
        </div>

        <div class="glass-card testimonial-card p-8">
          <div class="glass-card-glow" style="background: radial-gradient(circle at 50% 30%, rgba(139, 92, 246, 0.06), transparent 60%);" aria-hidden="true"></div>
          <div class="flex items-center gap-1 mb-4 relative">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-slate-300 text-sm leading-relaxed mb-6 relative italic">"Working with Elliott on Agentforce was a masterclass in AI implementation. He doesn't just understand the technology — he understands how to make it work for real business problems."</p>
          <div class="flex items-center gap-3 relative">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center text-white font-bold text-sm">RK</div>
            <div>
              <div class="text-white font-medium text-sm">Robert Kim</div>
              <div class="text-slate-500 text-xs">CTO, Enterprise SaaS Company</div>
            </div>
          </div>
        </div>

        <div class="glass-card testimonial-card p-8">
          <div class="glass-card-glow" style="background: radial-gradient(circle at 70% 30%, rgba(236, 72, 153, 0.06), transparent 60%);" aria-hidden="true"></div>
          <div class="flex items-center gap-1 mb-4 relative">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-slate-300 text-sm leading-relaxed mb-6 relative italic">"Elliott trained our entire architecture team on Data Cloud best practices. Six months later, we're delivering implementations twice as fast. His teaching style makes complex concepts accessible."</p>
          <div class="flex items-center gap-3 relative">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-red-500 flex items-center justify-center text-white font-bold text-sm">SP</div>
            <div>
              <div class="text-white font-medium text-sm">Sarah Patterson</div>
              <div class="text-slate-500 text-xs">Director of Architecture, Consulting Firm</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- LATEST POSTS (LinkedIn)                                     -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="py-32 md:py-40 relative" id="posts">
    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="text-center mb-16">
        <div class="section-divider" id="posts-divider"></div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4" id="posts-heading">
          Latest <span class="text-gradient">Thoughts</span>
        </h2>
        <p class="text-slate-500 text-lg" id="posts-sub">Follow me on LinkedIn for weekly insights on AI, Data Cloud, and enterprise architecture</p>
      </div>

      <div class="glass-card p-8 md:p-12" id="linkedin-embed">
        <div class="glass-card-glow" style="background: radial-gradient(circle at 50% 30%, rgba(59, 130, 246, 0.06), transparent 60%);" aria-hidden="true"></div>
        <div class="relative">
          <!-- LinkedIn Profile Badge -->
          <div class="flex flex-col md:flex-row items-center gap-8">
            <div class="flex-shrink-0">
              <a href="https://linkedin.com/in/elliottweed" target="_blank" rel="noopener" class="block">
                <img 
                  src="/photos/Headshot2024.jpg" 
                  alt="Elliott Weed on LinkedIn"
                  class="w-24 h-24 md:w-32 md:h-32 rounded-full border-2 border-blue-500/30 object-cover"
                />
              </a>
            </div>
            <div class="text-center md:text-left flex-1">
              <h3 class="text-xl md:text-2xl font-bold text-white mb-2">Elliott Weed</h3>
              <p class="text-slate-400 mb-4">Senior AI & Data Success Architect at Salesforce | Helping enterprises unlock the power of Agentforce & Data Cloud</p>
              <div class="flex flex-wrap justify-center md:justify-start gap-4 text-sm text-slate-500">
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                  </svg>
                  <span>1,000+ weekly views</span>
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
