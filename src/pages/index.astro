  <!-- GSAP + ALL ANIMATIONS                                       -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

    gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

    // ─── SCROLL PROGRESS BAR ───
    gsap.to('#scroll-progress', {
      scaleX: 1,
      ease: 'none',
      scrollTrigger: {
        trigger: 'body',
        start: 'top top',
        end: 'bottom bottom',
        scrub: 0.3,
      }
    });

    // ─── STICKY NAV ───
    ScrollTrigger.create({
      trigger: '#hero',
      start: 'bottom 80px',
      onEnter: () => document.getElementById('sticky-nav')?.classList.add('visible'),
      onLeaveBack: () => document.getElementById('sticky-nav')?.classList.remove('visible'),
    });

    // ─── ACTIVE NAV SECTION TRACKING ───
    const navSections = ['timeline', 'expertise', 'certs', 'contact'];

    function highlightNav(id: string) {
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = (link as HTMLAnchorElement).getAttribute('href');
        link.classList.toggle('active', href === `#${id}`);
      });
    }

    navSections.forEach(id => {
      ScrollTrigger.create({
        trigger: `#${id}`,
        start: 'top 50%',
        end: 'bottom 50%',
        onEnter: () => highlightNav(id),
        onEnterBack: () => highlightNav(id),
      });
    });

    // ─── MOUSE-TRACKING GLOW ───
    document.querySelectorAll<HTMLElement>('.glass-card, .contact-link').forEach(el => {
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width * 100);
        const y = ((e.clientY - rect.top) / rect.height * 100);
        el.style.setProperty('--mouse-x', x + '%');
        el.style.setProperty('--mouse-y', y + '%');
      });
    });

    // ─── HERO CANVAS PARTICLES ───
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let particles: Array<{x: number; y: number; vx: number; vy: number; size: number; alpha: number; color: string}> = [];
      let mouse = { x: -1000, y: -1000 };
      let animId: number;

      function resize() {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      const colors = ['59, 130, 246', '139, 92, 246', '236, 72, 153', '96, 165, 250'];

      function initParticles() {
        particles = [];
        const count = Math.min(80, Math.floor(canvas.width * canvas.height / 15000));
        for (let i = 0; i < count; i++) {
          particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.3,
            vy: (Math.random() - 0.5) * 0.3,
            size: Math.random() * 2 + 0.5,
            alpha: Math.random() * 0.4 + 0.1,
            color: colors[Math.floor(Math.random() * colors.length)]
          });
        }
      }
      initParticles();

      canvas.parentElement?.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });

      canvas.parentElement?.addEventListener('mouseleave', () => {
        mouse.x = -1000;
        mouse.y = -1000;
      });

      function drawParticles() {
        if (!ctx) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (let i = 0; i < particles.length; i++) {
          const p = particles[i];

          // Mouse interaction
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 150) {
            const force = (150 - dist) / 150;
            p.vx -= (dx / dist) * force * 0.02;
            p.vy -= (dy / dist) * force * 0.02;
          }

          p.x += p.vx;
          p.y += p.vy;

          // Dampen velocity
          p.vx *= 0.99;
          p.vy *= 0.99;

          // Wrap around
          if (p.x < 0) p.x = canvas.width;
          if (p.x > canvas.width) p.x = 0;
          if (p.y < 0) p.y = canvas.height;
          if (p.y > canvas.height) p.y = 0;

          // Draw particle
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${p.color}, ${p.alpha})`;
          ctx.fill();

          // Draw connections
          for (let j = i + 1; j < particles.length; j++) {
            const p2 = particles[j];
            const d = Math.sqrt((p.x - p2.x) ** 2 + (p.y - p2.y) ** 2);
            if (d < 120) {
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(p2.x, p2.y);
              ctx.strokeStyle = `rgba(${p.color}, ${(1 - d / 120) * 0.08})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }

        animId = requestAnimationFrame(drawParticles);
      }
      drawParticles();

      // Stop when hero not visible
      ScrollTrigger.create({
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        onLeave: () => cancelAnimationFrame(animId),
        onEnterBack: () => drawParticles(),
      });
    }

    // ─── HERO ORB PARALLAX ───
    gsap.to('#orb1', {
      y: -120,
      x: 40,
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 1 }
    });
    gsap.to('#orb2', {
      y: -70,
      x: -50,
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 1.2 }
    });
    gsap.to('#orb3', {
      y: -90,
      x: 60,
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 0.8 }
    });

    // ─── HERO ENTRANCE (Apple-style blur-to-clear) ───
    const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' }});

    heroTl
      .from('#hero-photo', { opacity: 0, scale: 0.85, filter: 'blur(12px)', duration: 1.2 })
      .from('#hero-name', { opacity: 0, y: 40, filter: 'blur(8px)', duration: 1 }, '-=0.6')
      .from('#hero-title', { opacity: 0, y: 25, filter: 'blur(6px)', duration: 0.8 }, '-=0.5')
      .from('#hero-sub', { opacity: 0, y: 20, filter: 'blur(4px)', duration: 0.8 }, '-=0.45')
      .from('#hero-stats .stat-card', {
        opacity: 0, y: 35, filter: 'blur(4px)', duration: 0.7, stagger: 0.12
      }, '-=0.35')
      .from('#scroll-hint', { opacity: 0, duration: 0.8 }, '-=0.2');

    // ─── STAT COUNTER ───
    const statNumbers = document.querySelectorAll('.stat-number');
    statNumbers.forEach((el) => {
      const target = parseInt((el as HTMLElement).dataset.target || '0');
      ScrollTrigger.create({
        trigger: el,
        start: 'top 85%',
        once: true,
        onEnter: () => {
          gsap.to({ val: 0 }, {
            val: target,
            duration: 1.5,
            ease: 'power2.out',
            onUpdate: function() {
              const current = Math.floor(this.targets()[0].val);
              el.textContent = current + '+';
            }
          });
        }
      });
    });

    // ─── SCROLL HINT FADE ───
    gsap.to('#scroll-hint', {
      opacity: 0,
      y: -10,
      scrollTrigger: {
        trigger: '#hero',
        start: '15% top',
        end: '30% top',
        scrub: true,
      }
    });

    // ─── SECTION HEADING PARALLAX ───
    document.querySelectorAll('#timeline, #expertise, #certs, #testimonials, #posts, #contact').forEach(section => {
      const heading = section.querySelector('h2');
      if (heading) {
        gsap.to(heading, {
          y: -20,
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'top 10%',
            scrub: 1.5,
          }
        });
      }
    });

    // ─── TIMELINE SECTION HEADER ───
    gsap.from('#timeline-divider', {
      scaleX: 0,
      scrollTrigger: { trigger: '#timeline-divider', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#timeline-heading', {
      opacity: 0, y: 30, filter: 'blur(6px)',
      scrollTrigger: { trigger: '#timeline-heading', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#timeline-sub', {
      opacity: 0, y: 20, filter: 'blur(4px)',
      scrollTrigger: { trigger: '#timeline-sub', start: 'top 85%', once: true },
      duration: 0.8,
      delay: 0.15,
      ease: 'power3.out',
    });

    // ─── TIMELINE LINE FILL ───
    const timelineFill = document.getElementById('timeline-fill');
    if (timelineFill) {
      ScrollTrigger.create({
        trigger: '#timeline-container',
        start: 'top 60%',
        end: 'bottom 40%',
        scrub: 0.5,
        onUpdate: (self) => {
          timelineFill.style.height = (self.progress * 100) + '%';
        }
      });
    }

    // ─── TIMELINE EVENTS (3D perspective entrance + blur) ───
    const events = document.querySelectorAll('.timeline-event');
    events.forEach((event, i) => {
      const card = event.querySelector('.glass-card');
      const dot = event.querySelector('.timeline-dot-inner');
      const year = event.querySelector('.year-marker');
      const isLeft = i % 2 === 0;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: event,
          start: 'top 80%',
          once: true,
        }
      });

      tl.from(dot, {
        scale: 0,
        opacity: 0,
        duration: 0.6,
        ease: 'back.out(1.7)',
      })
      .from(year, {
        opacity: 0,
        y: 10,
        duration: 0.5,
        ease: 'power3.out',
      }, '-=0.25')
      .from(card, {
        opacity: 0,
        x: isLeft ? 80 : -80,
        rotateY: isLeft ? 5 : -5,
        filter: 'blur(6px)',
        duration: 1,
        ease: 'power3.out',
      }, '-=0.35')
      .add(() => event.classList.add('is-active'));

      // Varied parallax depth on cards
      if (window.innerWidth > 768) {
        gsap.to(card, {
          y: -30 - (i % 3) * 8,
          scrollTrigger: {
            trigger: event,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.5,
          }
        });
      }
    });

    // ─── EXPERTISE SECTION ───
    gsap.from('#expertise-divider', {
      scaleX: 0,
      scrollTrigger: { trigger: '#expertise-divider', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#expertise-heading', {
      opacity: 0, y: 30, filter: 'blur(6px)',
      scrollTrigger: { trigger: '#expertise-heading', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#expertise-sub', {
      opacity: 0, y: 20, filter: 'blur(4px)',
      scrollTrigger: { trigger: '#expertise-sub', start: 'top 85%', once: true },
      duration: 0.8,
      delay: 0.15,
      ease: 'power3.out',
    });

    gsap.from('#expertise-grid .glass-card', {
      opacity: 0,
      y: 60,
      rotateX: 4,
      filter: 'blur(6px)',
      duration: 0.9,
      stagger: 0.15,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#expertise-grid',
        start: 'top 80%',
        once: true,
      }
    });

    // ─── CERTIFICATIONS ───
    gsap.from('#certs-divider', {
      scaleX: 0,
      scrollTrigger: { trigger: '#certs-divider', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#certs-heading', {
      opacity: 0, y: 30, filter: 'blur(6px)',
      scrollTrigger: { trigger: '#certs-heading', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#certs-sub', {
      opacity: 0, y: 20, filter: 'blur(4px)',
      scrollTrigger: { trigger: '#certs-sub', start: 'top 85%', once: true },
      duration: 0.8,
      delay: 0.15,
      ease: 'power3.out',
    });

    gsap.from('#certs-grid .cert-badge', {
      opacity: 0,
      scale: 0.85,
      y: 15,
      filter: 'blur(4px)',
      duration: 0.5,
      stagger: 0.06,
      ease: 'back.out(1.5)',
      scrollTrigger: {
        trigger: '#certs-grid',
        start: 'top 80%',
        once: true,
      }
    });

    // ─── TESTIMONIALS ───
    gsap.from('#testimonials-divider', {
      scaleX: 0,
      scrollTrigger: { trigger: '#testimonials-divider', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#testimonials-heading', {
      opacity: 0, y: 30, filter: 'blur(6px)',
      scrollTrigger: { trigger: '#testimonials-heading', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#testimonials-sub', {
      opacity: 0, y: 20, filter: 'blur(4px)',
      scrollTrigger: { trigger: '#testimonials-sub', start: 'top 85%', once: true },
      duration: 0.8,
      delay: 0.15,
      ease: 'power3.out',
    });
    gsap.from('#testimonials-grid .testimonial-card', {
      opacity: 0,
      y: 60,
      rotateX: 4,
      filter: 'blur(6px)',
      duration: 0.9,
      stagger: 0.15,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#testimonials-grid',
        start: 'top 80%',
        once: true,
      }
    });

    // ─── POSTS (LinkedIn) ───
    gsap.from('#posts-divider', {
      scaleX: 0,
      scrollTrigger: { trigger: '#posts-divider', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#posts-heading', {
      opacity: 0, y: 30, filter: 'blur(6px)',
      scrollTrigger: { trigger: '#posts-heading', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#posts-sub', {
      opacity: 0, y: 20, filter: 'blur(4px)',
      scrollTrigger: { trigger: '#posts-sub', start: 'top 85%', once: true },
      duration: 0.8,
      delay: 0.15,
      ease: 'power3.out',
    });
    gsap.from('#linkedin-embed', {
      opacity: 0,
      y: 40,
      filter: 'blur(6px)',
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#linkedin-embed',
        start: 'top 80%',
        once: true,
      }
    });

    // ─── CONTACT ───
    gsap.from('#contact-divider', {
      scaleX: 0,
      scrollTrigger: { trigger: '#contact-divider', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#contact-heading', {
      opacity: 0, y: 30, filter: 'blur(6px)',
      scrollTrigger: { trigger: '#contact-heading', start: 'top 85%', once: true },
      duration: 0.8,
      ease: 'power3.out',
    });
    gsap.from('#contact-sub', {
      opacity: 0, y: 20, filter: 'blur(4px)',
      scrollTrigger: { trigger: '#contact-sub', start: 'top 85%', once: true },
      duration: 0.8,
      delay: 0.15,
      ease: 'power3.out',
    });
    gsap.from('#contact-form-card', {
      opacity: 0,
      x: -40,
      filter: 'blur(6px)',
      duration: 0.9,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#contact-form-card',
        start: 'top 80%',
        once: true,
      }
    });
    gsap.from('.contact-quick-link', {
      opacity: 0,
      x: 40,
      filter: 'blur(4px)',
      duration: 0.7,
      stagger: 0.1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '.contact-quick-link',
        start: 'top 85%',
        once: true,
      }
    });

    // ─── SMOOTH NAV SCROLLING ───
    document.querySelectorAll('.sticky-nav a[href^="#"]').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (link as HTMLAnchorElement).getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          gsap.to(window, {
            duration: 1,
            scrollTo: { y: target as Element, offsetY: 60 },
            ease: 'power3.inOut',
          });
        }
      });
    });
  </script>
</Layout>
